          "content": {
            "size": 16436,
            "mimeType": "text/xml",
            "compression": 11567,
            "text": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n<language-string-table>\r\n\r\n\t<!-- BEGIN _Common.xml inclusion -->\r\n  <!-- base fonts -->\r\n  <field id=\"libfnt_MyriadPro\" bold=\"0\" italic=\"0\" font=\"Myriad Pro Semibold Cond\" />\r\n  <field id=\"libfnt_Meridien\" bold=\"0\" italic=\"0\" font=\"Meridien Medium Italic\" />\r\n  <!--standard status messages-->\r\n  <var id=\"ContactingServer\">Contacting server, please wait...</var>\r\n  <var id=\"loadingPleaseWait\">Loading please wait....</var>\r\n  <var id=\"placeYourBets\">Place your bets!</var>\r\n  <var id=\"noMoreBets\">No more bets!</var>\r\n  <var id=\"loadingAssets\">Loading Assets</var>\r\n  <var id=\"loadingBonusRound\">Loading Bonus Round</var>\r\n  <field id=\"lbl_br_Yes\">Yes</field>\r\n  <field id=\"lbl_br_No\">No</field>\r\n  <field id=\"lbl_start\">START</field>\r\n  <!-- Contest variables -->\r\n  <var id=\"CounterTypeId2\">HANDS</var>\r\n  <var id=\"CounterTypeId3\">DEALER HANDS</var>\r\n  <var id=\"CounterTypeId4\">PLAYER HANDS</var>\r\n  <var id=\"CounterTypeId5\">ROLLS</var>\r\n  <var id=\"CounterTypeId6\">SPINS</var>\r\n  <!-- Server Error Messages -->\r\n  <!-- AUTHENTICATION ERRORS -->\r\n  <var id=\"ERR_UNKNOWN\">An unknown error has occurred. Please try again later.</var>\r\n  <var id=\"ERR_POORCONN\">Connection/Browser Problem Detected.</var>\r\n  <var id=\"ERR_AUTH_FAILED\">Authentication failed or session expired. Please close your browser and log in again.</var>\r\n  <var id=\"ERR_AUTH_BLOCKED\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_DAY_WIN\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_DAY_LOSS\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_WEEK_WIN\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_WEEK_LOSS\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_LOCAL\">Your account is not enabled for real money play. Please contact customer service.</var>\r\n  <var id=\"ERR_BLOCK_LOCAL_AGENT\">Your account is not enabled for real money play. Please contact customer service.</var>\r\n  <var id=\"ERR_BLOCK_REMOTE\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_REMOTE_DISABLED\">Your account has been disabled. Please contact customer service.</var>\r\n  <var id=\"ERR_BLOCK_REMOTE_CASINO\">Your account is not enabled for real money play. Please contact customer service.</var>\r\n  <var id=\"ERR_BLOCK_REMOTE_ACCESS\">Your access to the casino is temporarily restricted.</var>\r\n  <var id=\"ERR_BLOCK_REMOTE_CREDIT\">Credit players are restricted from playing the casino.</var>\r\n  <!-- XML ERRORS -->\r\n  <var id=\"ERR_XML_LOADFAIL\">Language data load failed. Please contact support.</var>\r\n  <!-- BET-RELATED ERRORS -->\r\n  <var id=\"ERR_BET_FUNDS\">Insufficient funds to place bet, please make a deposit.</var>\r\n  <var id=\"ERR_BET_CANTCONT\">Insufficient funds to add new bet</var>\r\n  <var id=\"ERR_BET_RANGE\">Bet is outside allowed range</var>\r\n  <var id=\"ERR_BET_NOMO\">No more bet postings allowed at this time</var>\r\n  <var id=\"ERR_BET_DISABLED\">Bet is not allowed at this time</var>\r\n  <var id=\"ERR_BET_INCOMP\">Bet contains mutually exclusive bets</var>\r\n  <var id=\"ERR_BET_NOREMOVE\">Bet cannot be removed at this time</var>\r\n  <var id=\"ERR_BET_FORMAT\">Bad bet format</var>\r\n  <var id=\"ERR_BET_REQUIRED\">No bet was placed to start game</var>\r\n  <var id=\"ERR_WAGER_LOSS_LIMIT\">This wagering will exceed your wagering limitation. Please try a smaller amount or change your wagering limit.</var>\r\n\r\n  <!-- DATABASE ACCESS ERRORS -->\r\n  <var id=\"ERR_DB_NOCONN\">Database connection could not be established</var>\r\n  <var id=\"ERR_DB_EMPTY\">Database yielded no data during last query</var>\r\n  <var id=\"ERR_DB_NONXSET\">The next expected data records are missing</var>\r\n  <var id=\"ERR_DB_ACCESS\">Insufficient permissions for DB operation</var>\r\n  <var id=\"ERR_DB_BADDATA\">Incorrect data returned by database.</var>\r\n  <!--WEB-SPECIFIC ERRORS-->\r\n  <var id=\"ERR_WEB_CALLFAILED\">Server Call Failed</var>\r\n  <!-- GAME STATUS-RELATED ERRORS -->\r\n  <var id=\"ERR_GAME_SESSIONFAIL\">Could not start gaming session</var>\r\n  <var id=\"ERR_GAME_CLOSED\">Game is currently closed, please come back later</var>\r\n  <var id=\"ERR_GAME_PENDING\">Cannot start new game due to unfinished ones</var>\r\n  <var id=\"ERR_GAME_REC\">Game recovery error</var>\r\n  <var id=\"ERR_GAME_REC_NONE\">Specified game does not exist</var>\r\n  <var id=\"ERR_GAME_REC_CLOSE\">Cannot resume a finished game</var>\r\n  <var id=\"ERR_GAME_REC_FAIL\">Game recovery failure due to damaged records</var>\r\n  <var id=\"ERR_GAME_NOCHG\">Player did not change bet/game status in order to proceed</var>\r\n  <var id=\"ERR_GAME_BADACT\">Invalid action requested</var>\r\n  <var id=\"ERR_GAME_BADPAR\">Invalid or missing parameter</var>\r\n  <var id=\"ERR_GAME_PRIZETBL\">Could not obtain prize table</var>\r\n  <var id=\"ERR_GAME_WAITFORGAME\">Please wait for one game to load before opening a second one\"</var>\r\n  <!-- LICENSING ERRORS -->\r\n  <var id=\"ERR_LICENSE_EXPIRED\">Casino is closed.</var>\r\n  <var id=\"ERR_LICENSE_INVALID\">Casino is closed.</var>\r\n  <var id=\"ERR_LICENSE_NONE\">Casino is closed.</var>\r\n  <!-- VERSIONING ERRORS -->\r\n  <var id=\"ERR_VER_DEPR_SP\">Deprecated stored procedure</var>\r\n  <var id=\"ERR_VER_DEPR_ACTION\">Deprecated action</var>\r\n  <!-- INTEGRITY ERRORS -->\r\n  <var id=\"ERR_INT_INTERNAL\">Internal Error. Please contact technical support.</var>\r\n  <var id=\"ERR_INT_HACKED\">Internal Error: non-authorized product tampering detected.</var>\r\n  <!-- PROGRESSIVE BETS SUBSYSTEM -->\r\n  <var id=\"ERR_PROG_NOENTRY\">No progressive data entry available</var>\r\n  <!-- INTERNAL DEVELOPER ERRORS -->\r\n  <var id=\"ERR_DEVEL_RES_DATRDOPEN\">Internal Error: DataReader has not been detached</var>\r\n  <!-- SPECIFIC PER-GAME ERRORS -->\r\n  <var id=\"ERR_BJK_SPLIT\">Cannot split any more hands</var>\r\n  <var id=\"ERR_BJK_HANDS\">Invalid number of hands</var>\r\n  <var id=\"ERR_CP_ODDS_STR\">Will not accept odds without straight bet</var>\r\n  <var id=\"ERR_CP_ODDS_TOP\">Will not accept odds that high</var>\r\n  <var id=\"ERR_PG_CARD_NOARR\">Player's cards should be split into front and back hands</var>\r\n  <!-- TOURNAMENT MESSAGES -->\r\n  <var id=\"ERR_ENTRY_FINISHED\">Your contest entry has been completed. Close the window and return to the contest lobby.</var>\r\n  <var id=\"ERR_TRNY_BUY_ERROR\">Unable to purchase entry</var>\r\n  <var id=\"ERR_TRNY_BUYIN_CLOSED\">Tournament registration has closed</var>\r\n  <var id=\"ERR_TRNY_CLOSED\">Tournament has completed</var>\r\n  <var id=\"ERR_TRNY_INELIGIBLE\">You are not eligible to enter this tournament</var>\r\n  <var id=\"ERR_TRNY_INVITE\">Tournament is by invitation only</var>\r\n  <var id=\"ERR_TRNY_REBUY_MAX\">No more rebuys are allowed</var>\r\n  <var id=\"ERR_TRNY_REBUY_NONE\">No rebuys are allowed</var>\r\n  <var id=\"ERR_TRNY_START\">Tournament has not begun</var>\r\n  <!-- BONUS MESSAGES -->\r\n  <var id=\"ERR_BONUS_RELEASED\">Your bonus rollover requirement is complete.</var>\r\n  <var id=\"ERR_BONUS_EXPIRED\">Your bonus has expired.</var>\r\n  <var id=\"ERR_BONUS_FORFEIT\">Your bonus is no longer available.</var>\r\n  <var id=\"ERR_BONUS_VOID\">Your bonus is no longer available.</var>\r\n  <var id=\"ERR_BONUS_NOACTIVE\">Your bonus is no longer available.</var>\r\n  <!-- CURRENCY MESSAGES -->\r\n  <var id=\"ERR_CURRENCY_RESTRICTED\">Your account currency is not allowed for this game</var>\r\n  <var id=\"ERR_NO_CURRENCY_CONV\">Your account currency is not allowed for this game</var>\r\n  <!-- CASHIER MESSAGES -->\r\n  <var id=\"ERR_CASHIER_DISABLED\">Cashier is unavailable.</var>\r\n  <var id=\"ERR_CASHIER_INVALID\">Invalid amount</var>\r\n  <var id=\"ERR_CASHIER_IMPOSSIBLE\">No transfer is possible at this time</var>\r\n  <var id=\"ERR_CASHIER_MIN\">You must transfer at least  1</var>\r\n  <var id=\"ERR_CASHIER_MAX\">You can't transfer more than ~1</var>\r\n  <var id=\"ERR_CASHIER_NODECIMAL\">Buy-in for whole amounts only, no fractions.</var>\r\n  <!-- MORE GAME ERRORS -->\r\n  <var id=\"ERR_GAME_INVALID_CONFIG\">Game is currently closed, please come back later</var>\r\n  <var id=\"ERR_GAME_MIN_CARDS\">You must buy more cards.</var>\r\n  <var id=\"ERR_GAME_MAX_CARDS\">Maximum number of cards exceeded.</var>\r\n  <var id=\"ERR_GAME_INVALID_CARD\">Card you attempted to purchase appears to be invalid.</var>\r\n  <var id=\"ERR_GAME_INVALID_TICKET\">Ticket you attempted to purchase appears to be invalid.</var>\r\n  <var id=\"ERR_GAME_MAX_TICKETS\">Maximum number of tickets exceeded.</var>\r\n  <var id=\"ERR_TRANS_FAILURE\">Transaction failure, contact customer support.</var>\r\n  <var id=\"ERR_BALL_READER\">Ball reader error. Game will be graded manually.</var>\r\n\r\n\r\n  <!-- Main Menu -->\r\n  <field id=\"MainMenu_fld_GameRules\">HELP</field>\r\n  <field id=\"MainMenu_fld_Cashier\">CASHIER</field>\r\n  <field id=\"MainMenu_fld_GoToLobby\">EXIT GAME</field>\r\n  <field id=\"MainMenu_fld_History\">HISTORY</field>\r\n  <field id=\"MainMenu_fld_RealMoney\">REAL MONEY</field>\r\n  <field id=\"MainMenu_fld_FreePlay\">PLAY FOR FUN</field>\r\n  <field id=\"MainMenu_fld_Tournament\">TOURNAMENT</field>\r\n  <field id=\"MainMenu_fld_Demo\">PLAY FOR FUN</field>\r\n  <field id=\"MainMenu_fld_Test\">TEST ACCOUNT</field>\r\n  <field id=\"MainMenu_fld_Bonus\">BONUS PLAY</field>\r\n  <field id=\"MainMenu_fld_Progressive\">PROGRESSIVE</field>\r\n  <field id=\"MainMenu_fld_Jackpot\">JACKPOT!</field>\r\n  <!-- End Main Menu -->\r\n  <!-- BuyIn -->\r\n  <field id=\"BuyIn_fld_Cancel\">Cancel</field>\r\n  <field id=\"BuyIn_fld_Ok\">Ok</field>\r\n  <field id=\"BuyIn_fld_Buy\">Buy</field>\r\n  <field id=\"BuyIn_fld_Exit\">Exit</field>\r\n  <field id=\"BuyIn_fld_Reload\">Reload</field>\r\n  <field id=\"BuyIn_fld_Deposit\">Deposit</field>\r\n  <field id=\"BuyIn_fld_YourBal\" size=\"12\">Your Bankroll:</field>\r\n  <field id=\"BuyIn_fld_Title\">Buy-In (~1)</field>\r\n  <field id=\"BuyIn_fld_BuyTab\">Bring money to the table</field>\r\n  <field id=\"BuyIn_fld_TakeTab\">Take money off the table</field>\r\n  <field id=\"BuyIn_fld_BuyAll\">Bring your whole balance (~1)</field>\r\n  <field id=\"BuyIn_fld_BuyMax\">Maximum for the table (~1)</field>\r\n  <field id=\"BuyIn_fld_BuyMin\">Minimum for the table (~1)</field>\r\n  <field id=\"BuyIn_fld_OtherAmount\">Other amount:</field>\r\n  <field id=\"BuyIn_fld_BuyIn\">Register, buy an entry (~1)</field>\r\n  <field id=\"BuyIn_fld_Rebuy\">Rebuy, play a new entry (~1)</field>\r\n  <field id=\"BuyIn_fld_EntryPos\">Your entry is in place #~1</field>\r\n  <field id=\"BuyIn_fld_TakeAll\">All the game's balance (~1)</field>\r\n  <field id=\"BuyIn_fld_TakeWon\">Only your winnings (~1)</field>\r\n  <!-- new Buy In Fields December 2012 -->\r\n  <field id=\"BuyIn_fld_DepositOnly\">Deposit Only</field>\r\n  <field id=\"BuyIn_fld_ClaimBonus\">Claim Bonus</field>\r\n  <field id=\"BuyIn_fld_BonusAmountX\">~1 Bonus</field>\r\n  <field id=\"BuyIn_fld_BonusRolloverX\">~1 Rollover</field>\r\n  <field id=\"BuyIn_fld_BonusBalance\">Bonus Balance</field>\r\n  <field id=\"BuyIn_fld_BonusRollover\">Rollover</field>\r\n  <field id=\"BuyIn_fld_BonusCurrent\">Current</field>\r\n  <field id=\"BuyIn_fld_Amount\">Amount</field>\r\n  <field id=\"BuyIn_fld_Withdrawal\">Withdrawal</field>\r\n  <field id=\"BuyIn_fld_BonusLocked\">Bonus Locked</field>\r\n  <field id=\"BuyIn_fld_BonusDisclaimer\">If bonus is claimed deposits cannot be withdrawn from casino until rollover is met.</field>\r\n  <!-- Options Menu -->\r\n  <field id=\"lbl_Options_History\">History</field>\r\n  <field id=\"lbl_Options_Buyin\">Cashier</field>\r\n  <field id=\"lbl_Options_Help\">Help</field>\r\n  <field id=\"lbl_Options_Fastplay\">Fastplay</field>\r\n  <field id=\"lbl_btn_Options\">OPTIONS</field>\r\n  <field id=\"lbl_btn_Lobby\">LOBBY</field>\r\n  <field id=\"lbl_title_Options\">OPTIONS</field>\r\n  <field id=\"lbl_Sounds_On\">SOUNDS ON</field>\r\n  <field id=\"lbl_Sounds_Off\">SOUNDS OFF</field>\r\n  <field id=\"lbl_Options_Rebates\">Rebates</field>\r\n  <field id=\"lbl_Optional_Sound\">Play with sounds?</field>\r\n  <field id=\"lbl_Options_Voices\">Voices</field>\r\n  <field id=\"lbl_Options_Sound\">Sounds</field>\r\n\r\n   <field id=\"lbl_Payouts\">PAYOUTS</field>\r\n\r\n  <!-- Rebates HTML5 -->\r\n  <field id=\"lbl_title_Rebates\">REBATES</field>\r\n  <field id=\"lbl_current_balance\">Current Balance</field>\r\n  <field id=\"lbl_rebate_amount\">Your rebate amount</field>\r\n  <field id=\"lbl_rebate_claim\">Claim Rebate</field>\r\n\r\n\t<!-- Rebates Flash -->\r\n  <field id=\"Rebate_fld_Title\">REBATES</field>  <!-- you can copy lbl_title_Rebates -->\r\n  <field id=\"Rebate_fld_YourBal\">Balance</field>\r\n  <field id=\"Rebate_fld_Amount\">Amount</field>\r\n  <field id=\"Rebate_fld_Claim\">Claim</field>\r\n  <field id=\"Rebate_fld_Deposit\">Claim</field>\r\n  <field id=\"Rebate_fld_Withdrawal\">History</field>\r\n\r\n\r\n  <!-- Cashier -->\r\n  <field id=\"lbl_title_Cashier\">CASHIER</field>\r\n  <field id=\"lbl_transfer_casino\">Transfer to Casino</field>\r\n  <field id=\"lbl_btn_transfer\">Transfer</field>\r\n\r\n  <!-- Hand names deserve to be shared -->\r\n  <field id=\"fld_RF\">Royal Flush</field>\r\n  <field id=\"fld_NR\">Natural Royal</field>\r\n  <field id=\"fld_5K\">Five of a Kind</field>\r\n  <field id=\"fld_SF\">Straight Flush</field>\r\n  <field id=\"fld_4K\">Four of a Kind</field>\r\n  <field id=\"fld_FH\">Full House</field>\r\n  <field id=\"fld_FL\">Flush</field>\r\n  <field id=\"fld_ST\">Straight</field>\r\n  <field id=\"fld_3K\">Three of a Kind</field>\r\n  <field id=\"fld_2P\">Two Pairs</field>\r\n  <field id=\"fld_KB\">Kings or Better</field>\r\n  <field id=\"fld_JB\">Jacks or Better</field>\r\n  <field id=\"fld_TB\">10s or Better</field>\r\n  <!-- Chip Tutorial Labels -->\r\n  <field id=\"Tutorial_Title\">TUTORIAL</field>\r\n  <field id=\"Tutorial_NeverAgain\">Don't show again</field>\r\n  <field id=\"Tutorial_RemoveBets\">To remove bets, drag chips off table.</field>\r\n  <!-- Remove Bets -->\r\n  <field id=\"Tutorial_RemoveBets\">To remove bets, drag chips off table.</field>\r\n\r\n  <!-- Auto Play -->\r\n  <field id=\"lbl_Stop_Auto\">Stop AutoPlay</field>\r\n  <field id=\"lbl_StopAuto_pt1\">If Single Win Exceeds</field>\r\n  <field id=\"lbl_StopAuto_pt2\">Stop if total loss exceeds</field>\r\n\r\n  <!-- Reality Check -->\r\n  <field id=\"lbl_Reality_Check\">Reality Check</field>\r\n  <field id=\"lbl_RC_1\">You have been playing for ~1 minutes</field>\r\n  <field id=\"lbl_RC_2\">Please give me a reality check every:</field>\r\n  <field id=\"lbl_RC_3\">No thanks, I do not need a reality check.</field>\r\n  <field id=\"lbl_RC_4\">Close Game</field>\r\n\r\n\r\n\r\n\r\n\r\n\r\n  <!-- END _Common.xml inclusion -->\r\n\r\n\r\n\t<var id=\"txt_PercentJackpot\">~1 Jack</var>\r\n\t<var id=\"txt_WholeJackpot\" autosize=\"center\">Jackpot</var>\r\n\r\n\t<!-- this is actually the ONLY non-blank statusTxt message -->\r\n\r\n\t<!-- game-specific error messages -->\r\n\t<var id=\"ERR_VP_DATA_BADSESSION\">Incorrect session data returned by server</var>\r\n\t<var id=\"ERR_VP_DATA_BADLIMITS\">Incorrect bet limit parameters returned by server</var>\r\n\t<var id=\"ERR_VP_DATA_BADFUNDS\">Incorrect funds data returned by server</var>\r\n\t<var id=\"ERR_VP_DATA_BADCOINVALS\">Incorrectly constructed lists of coin values returned by server</var>\r\n\t<var id=\"ERR_VP_DATA_BADCARDS\">Incorrect card data returned by server</var>\r\n\t<var id=\"ERR_VP_DATA_BADRESULT\">Incorrect play result returned by server</var>\r\n\r\n\t<var id=\"ERR_VP_BET_BIGGERTHANMAX\">Not allowed -- your bet would exceeded the permitted maximum (~1).</var>\r\n\r\n\t<!--labels in the payouts table-->\r\n\t<field id=\"lbl_Credits\">CREDITS</field>\r\n\t<field id=\"lbl_Coins\">Coins</field>\r\n\t<field id=\"fld_4D\">Four Deuces</field>\r\n\t<field id=\"fld_JR\">Jokers Royal</field>\r\n\t<field id=\"fld_DR\">Deuces Royal</field>\r\n\t<field id=\"fld_A8\">Aces or Eights</field>\r\n\t<field id=\"fld_BA\">4 Aces + 2-4</field>\r\n\t<field id=\"fld_4A\">Four Aces</field>\r\n\t<field id=\"fld_B4\">4 of Kind 2-4+A-4</field>\r\n\t<field id=\"fld_44\">4 of a Kind of 2-4</field>\r\n\t<field id=\"fld_47\">Four Sevens</field>\r\n\t<field id=\"fld_Q2\">Natural 4 Deuces</field>\r\n\t<field id=\"fld_5W\">Five Wilds</field>\r\n\t<field id=\"fld_WR\">Wild Royal Flush</field>\r\n\t<field id=\"fld_4KnotB4\">4 of a Kind of 5-K</field>\r\n\t<field id=\"lbl_InsertCoins\">INSERT COINS</field>\r\n\r\n\t<field id=\"lbl_PlaceYourBets\">Bet 1 to 5 coins to play.</field>\t<field id=\"lbl_CoinValue\">Coin Value</field>\r\n\t<field id=\"lbl_Balance\">Balance:</field>\r\n\t<field id=\"lbl_TotalWin\">Won:</field>\r\n\t<field id=\"lbl_TotalBet\">Bet:</field>\r\n\r\n\t<!--labels in the controls-->\r\n\t <field id=\"fld_PayoutChart\">PAYOUTS</field>\r\n\t<field id=\"fld_BetMax\">BET MAX</field>\r\n\t<field id=\"fld_BetOne\">BET ONE</field>\r\n\t<field id=\"fld_Deal\">DEAL</field>\r\n\t<field id=\"fld_Draw\">DRAW</field>\r\n\t<field id=\"fld_Collect\">COLLECT</field>\r\n\t<field id=\"fld_Double\">DOUBLE</field>\r\n\t<field id=\"fld_HoldBut\">HOLD</field>\r\n\t<field id=\"fld_HeldBut\">HOLD</field>\r\n\t<field id=\"fld_PickBut\">PICK</field>\r\n\t</language-string-table>\r\n"
