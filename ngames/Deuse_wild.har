          "content": {
            "size": 10890,
            "mimeType": "text/html",
            "compression": 9202,
            "text": "<!DOCTYPE html>\r\n<html>\r\n    <head><meta charset=\"utf-8\">\r\n        <title>Video Poker</title>\r\n        <meta name=\"viewport\" content=\"width=device-width,minimum-scale=0.9, maximum-scale=0.9, initial-scale=0.9,user-scalable=0, minimal-ui\">\r\n        <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\r\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n\r\n        <link rel=\"stylesheet\" href=\"_build/Common/styles/common-styles.1.2.0-vp_classic.min.css\"/>\r\n        <link rel=\"stylesheet\" href=\"_build/styles/vp-classic-d-style.min.css\">\r\n    </head>\r\n    <body>\r\n        <script id=\"paytable-template\" type=\"text/x-jquery-tmpl\">\r\n            <tr>\r\n                <th class=\"right-text\"><span class=\"is-ml\" ml-key=\"lbl_Coins\"/>:</th>\r\n                <th>1</th>\r\n                <th>2</th>\r\n                <th>3</th>\r\n                <th>4</th>\r\n                <th>5</th>\r\n            </tr>\r\n            {{each payments}}\r\n                <tr>\r\n                    <td class=\"left-text\">${payDescription}</td>\r\n                    <td >${pay1}</td>\r\n                    <td >${pay2}</td>\r\n                    <td >${pay3}</td>\r\n                    <td >${pay4}</td>\r\n                    <td >${pay5}</td>\r\n                </tr>\r\n            {{/each}}\r\n        </script>\r\n        <script id=\"paytable-main-template\" type=\"text/x-jquery-tmpl\">\r\n            <tr>\r\n                <th class=\"right-text\"><span class=\"is-ml\" ml-key=\"lbl_Coins\"/>:</th>\r\n                <th>1</th>\r\n                <th>2</th>\r\n                <th>3</th>\r\n                <th>4</th>\r\n                <th>5</th>\r\n            </tr>\r\n            {{each payments}}\r\n                <tr>\r\n                    <td class=\"left-text\">${payDescription}</td>\r\n                    <td >${pay1}</td>\r\n                    <td >${pay2}</td>\r\n                    <td >${pay3}</td>\r\n                    <td >${pay4}</td>\r\n                    <td >${pay5}</td>\r\n                </tr>\r\n            {{/each}}\r\n        </script>\r\n        <div id=\"main-content\" class=\"main-content\">\r\n            <div id=\"history-container\" class=\"history-container\">\r\n                <a class=\"btn-history-back\" id=\"btn-history-back\"></a>\r\n                <div id=\"history-data\" class=\"history-data\"></div>\r\n            </div>\r\n            <div id=\"game-content\" class=\"game-content\">\r\n                <div class=\"nav-icons\">\r\n                    <a class=\"nav-icon btn-lobby\" id=\"btn-lobby\"></a>\r\n                    <a class=\"nav-icon btn-sounds sounds-on\" id=\"btn-sounds\"></a>\r\n                    <a class=\"nav-icon btn-history\" id=\"btn-history\"></a>\r\n                    <a class=\"nav-icon btn-cashier\" id=\"btn-cashier\"></a>\r\n                </div>\r\n\r\n                <!-- <a class=\"nav-icon btn-lobby\" id=\"btn-lobby\"></a>\r\n                <a class=\"nav-icon btn-sounds sounds-on\" id=\"btn-sounds\"></a>\r\n                <a class=\"nav-icon btn-history\" id=\"btn-history\"></a>\r\n                <a class=\"nav-icon btn-cashier\" id=\"btn-cashier\"></a> -->\r\n                <img id=\"game-content-img\" class=\"game-bkgd\"/>\r\n\r\n                <div id=\"block-portrait\" class=\"block-portrait\">\r\n                    <img src=\"_build/img/rotate-screen-icon.gif\" class=\"rotate-icon\"/>\r\n                </div> \r\n\r\n                <!-- <div class=\"paytable-block\">\r\n                    <div class=\"info coin-text\"><div><span class=\"is-ml\" ml-key=\"lbl_Coins\"></span></div></div>\r\n                    <div id=\"coin1\" class=\"info\"><div><span>1</span></div></div>\r\n                    <div id=\"coin2\" class=\"info odd-column\"><div><span>2</span></div></div>\r\n                    <div id=\"coin3\" class=\"info\"><div><span>3</span></div></div>\r\n                    <div id=\"coin4\" class=\"info odd-column\"><div><span>4</span></div></div>\r\n                    <div id=\"coin5\" class=\"info\"><div><span>5</span></div></div>\r\n                </div>\r\n                <div class=\"result-block\">\r\n                    <div id=\"result-hand-name\" class=\"hand-name\"><span></span></div>\r\n                    <div id=\"result-coin1\" class=\"coin-pay\"><div><span></span></div></div>\r\n                    <div id=\"result-coin2\" class=\"coin-pay odd-column\"><div><span></span></div></div>\r\n                    <div id=\"result-coin3\" class=\"coin-pay\"><div><span></span></div></div>\r\n                    <div id=\"result-coin4\" class=\"coin-pay odd-column\"><div><span></span></div></div>\r\n                    <div id=\"result-coin5\" class=\"coin-pay\"><div><span></span></div></div>\r\n                    <div id=\"won-panel\" class=\"won-panel\">\r\n                        <span class=\"is-ml\" ml-key=\"lbl_TotalWin\"></span> \r\n                        <span id=\"won-panel-value\" class=\"value\">0.00</span>\r\n                    </div>\r\n                </div> -->\r\n                <div class=\"paytable-block\">\r\n                    <table id=\"paytable-main\"></table>\r\n                </div>\r\n                <div class=\"cards-block\">\r\n                    <a id=\"btn-card1\" class=\"card card-enable first-card\"><div><span class=\"is-ml\" ml-key=\"fld_HoldBut\"></span></div></a>\r\n                    <a id=\"btn-card2\" class=\"card card-enable\"><div><span class=\"is-ml\" ml-key=\"fld_HoldBut\"></span></div></a> \r\n                    <a id=\"btn-card3\" class=\"card card-enable\"><div><span class=\"is-ml\" ml-key=\"fld_HoldBut\"></span></div></a> \r\n                    <a id=\"btn-card4\" class=\"card card-enable\"><div><span class=\"is-ml\" ml-key=\"fld_HoldBut\"></span></div></a> \r\n                    <a id=\"btn-card5\" class=\"card card-enable\"><div><span class=\"is-ml\" ml-key=\"fld_HoldBut\"></span></div></a>\r\n                    <!-- <div id=\"win-message\" class=\"message-panel\"><div><span class=\"is-ml\" ml-key=\"lbl_TotalWin\"></span> <span id=\"credits-won-amount\" class=\"value\">0.00</span></div></div> -->\r\n                    <!-- <div id=\"error-message\" class=\"message-panel\"><div class=\"error-msg\"><span class=\"error-msg\"></span></div></div> -->\r\n                </div>\r\n                <div class=\"cards-btns-block\">\r\n\r\n                    <a id=\"btn-card1-hold\" class=\"btn-card-hold state-hold\">\r\n                        <div class=\"center-content\">\r\n                            <span class=\"center-content-elem is-ml\" ml-key=\"fld_HoldBut\"></span>\r\n                            <span class=\"center-content-elem is-ml\" ml-key=\"fld_PickBut\"></span>\r\n                        </div>\r\n                    </a>\r\n                    <a id=\"btn-card2-hold\" class=\"btn-card-hold state-hold\"><div class=\"center-content\"><span class=\"center-content-elem is-ml\" ml-key=\"fld_HoldBut\"></span><span class=\"center-content-elem is-ml\" ml-key=\"fld_PickBut\"></span></div></a>\r\n                    <a id=\"btn-card3-hold\" class=\"btn-card-hold state-hold\"><div class=\"center-content\"><span class=\"center-content-elem is-ml\" ml-key=\"fld_HoldBut\"></span><span class=\"center-content-elem is-ml\" ml-key=\"fld_PickBut\"></span></div></a>\r\n                    <a id=\"btn-card4-hold\" class=\"btn-card-hold state-hold\"><div class=\"center-content\"><span class=\"center-content-elem is-ml\" ml-key=\"fld_HoldBut\"></span><span class=\"center-content-elem is-ml\" ml-key=\"fld_PickBut\"></span></div></a>\r\n                    <a id=\"btn-card5-hold\" class=\"btn-card-hold state-hold\"><div class=\"center-content\"><span class=\"center-content-elem is-ml\" ml-key=\"fld_HoldBut\"></span><span class=\"center-content-elem is-ml\" ml-key=\"fld_PickBut\"></span></div></a>\r\n                </div>\r\n                <div class=\"money-block\">\r\n                    <div class=\"credits\"><span class=\"is-ml\" ml-key=\"lbl_Credits\"></span> <span id=\"credits-value\" class=\"value\">0</span></div>\r\n                    <div class=\"won\"><span class=\"is-ml\" ml-key=\"lbl_TotalWin\"></span> <span id=\"won-value\" class=\"value\">-</span></div>\r\n                    <div class=\"bet\"><span class=\"is-ml\" ml-key=\"lbl_TotalBet\"></span> <span id=\"bet-value\" class=\"value\">0</span></div>\r\n                </div>\r\n                <div class=\"buttons-block\">\r\n                    \r\n                    <a id=\"btn-collect\" class=\"button orange first-button hidden\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"white-text is-ml\" ml-key=\"fld_Collect\"></span></div></div></a> \r\n                    <a id=\"btn-double\" class=\"button orange hidden\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"white-text is-ml\" ml-key=\"fld_Double\"></span></div></div></a> \r\n\r\n                    <a id=\"btn-bet-one\" class=\"button bet-one-enable\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"bet-one-text is-ml\" ml-key=\"fld_BetOne\"></span></div></div></a> \r\n                    <a id=\"btn-bet-max\" class=\"button bet-max-enable hidden\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"bet-max-text is-ml\" ml-key=\"fld_BetMax\"></span></div></div></a>\r\n                    <a id=\"btn-deal\" class=\"button deal-enable hidden\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"deal-text is-ml\" ml-key=\"fld_Deal\"></span></div></div></a>\r\n                    <a id=\"btn-draw\" class=\"button draw-enable hidden\"><div class=\"main-div\"><div class=\"text-div\"><span class=\"draw-text is-ml\" ml-key=\"fld_Draw\"></span></div></div></a>\r\n                    <a id=\"btn-coin-min\" class=\"button coin-min-enable\">\r\n                    </a> \r\n                    <div id=\"btn-change-coin\" class=\"button coin-enable\">\r\n                        <div class=\"main-div\">\r\n                            <div class=\"coin-button-content\"><span class=\"click-text is-ml\" ml-key=\"lbl_CoinValue\"></span> <span id=\"coin-value-text\" class=\"coin-value-text\"></span></div>\r\n                        </div>\r\n                    </div> \r\n                    <a id=\"btn-coin-plus\" class=\"button coin-plus-enable\">\r\n                    </a> \r\n                </div>\r\n                <div id=\"paytable-popup\" class=\"paytable-popup\">\r\n                    <div class=\"opaque-bkgd\"></div>\r\n                    <div class=\"paytable-bkgd\"></div>\r\n                    <div class=\"paytable-div\">\r\n                        <table id=\"paytable\"></table>\r\n                    </div>\r\n                    <div class=\"payout-text\"><span class=\"is-ml\" ml-key=\"fld_PayoutChart\">></span></div>\r\n                    <div id=\"game-name\" class=\"game-name\"><span>Game Name</span></div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        \r\n        <script src=\"../Common/accounting.min.js\"></script>\r\n        <script src=\"../Common/jquery.js\"></script>\r\n        <script src=\"../Common/jquery.tmpl.js\"></script>\r\n        <script src=\"../Common/soundjs-0.6.2.min.js\"></script>\r\n        <script src=\"../Common/preloadjs-0.6.2.min.js\"></script>\r\n\r\n        <script src=\"../Common/global-config.js\"></script>\r\n        <script src=\"_build/Common/common-vp-classic-v2.min.js\"></script>\r\n\r\n        <script src=\"_build/js/game-config.js\"></script>\r\n        <script src=\"_build/js/vp-classic-d-game.min.js\"></script>\r\n    </body>\r\n</html>"
          },
