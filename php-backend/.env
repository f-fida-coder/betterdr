APP_ENV=development
PORT=5000
CORS_ALLOW_ALL=true
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5000,http://127.0.0.1:5000,http://localhost:5050,http://127.0.0.1:5050,https://bettorplays247.com,https://www.bettorplays247.com
JWT_SECRET=d3ec06a495135eb2e6e56e5398447dda6aaf96cf795ab1192521a8cf22ff703a
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
ODDS_API_KEY=36509f41fa6f6e51b4a789e54a4c295f
ODDS_API_MARKETS=h2h,spreads,totals
MANUAL_FETCH_MODE=false
# Worker wake interval. Acts as the tick rate that checks which sports are
# "due" based on their per-tier cadence. 5 = GCD of tier cadences (10/15/30).
ODDS_CRON_MINUTES=5
# Tiered cadence: each sport belongs to exactly one tier, and is fetched only
# every Tx minutes. Sports not listed in ODDS_TIER1_SPORTS / ODDS_TIER2_SPORTS
# fall to tier 3 automatically. If both tier lists are empty, tiering is off.
ODDS_TIER1_SPORTS=basketball_nba,cricket_ipl,soccer_epl,soccer_uefa_champs_league,soccer_spain_la_liga,baseball_mlb,icehockey_nhl,tennis_atp_madrid_open
ODDS_TIER1_CRON_MINUTES=10
ODDS_TIER2_SPORTS=soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_usa_mls,cricket_odi,cricket_psl,tennis_wta_madrid_open,basketball_euroleague,basketball_wnba,mma_mixed_martial_arts,boxing_boxing
ODDS_TIER2_CRON_MINUTES=15
ODDS_TIER3_CRON_MINUTES=30
# When false, tier 3 sports are skipped by the per-event extended-odds pass
# (player props, alt lines, team totals, period markets) — big credit saver
# that costs deep-market coverage on long-tail sports.
ODDS_TIER3_EXTENDED_SYNC=false
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
ODDS_SCORES_DAYS_FROM=0
# Auto-discover: when true, the sync service calls /v4/sports on each
# cycle (cached 1h) and pulls every currently-active sport. No need to
# maintain ODDS_ALLOWED_SPORTS. To exclude specific sports even in
# auto mode, list their keys in ODDS_DISCOVERY_EXCLUDE (comma-separated).
ODDS_AUTO_DISCOVER_SPORTS=true
ODDS_DISCOVERY_EXCLUDE=politics_us_presidential_election_winner
# Sync period markets (1H/2H/Q1-Q4 for basketball/football, F1/F5/F7
# for baseball, P1-P3 for hockey) + team totals + alt lines via the
# per-event endpoint. Enables the period tab bar on every match card.
ODDS_EXTENDED_SYNC_ENABLED=false
IP_BLOCKING_ENABLED=true
DUPLICATE_IP_BLOCK_ENABLED=false
IP_ALLOWLIST=::1,127.0.0.1
ODDS_API_ODDS_FORMAT=decimal
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=betterdr_local
MYSQL_USER=root
MYSQL_PASSWORD=1245!
MYSQL_TABLE_PREFIX=
MAX_DB_CONNECTIONS=100

# Phase 0 observability thresholds (health alerts)
ALERT_API_P95_MS=700
ALERT_API_5XX_RATE_PERCENT=2
ALERT_ODDS_SYNC_AGE_SECONDS=300
ALERT_WORKER_FAIL_RATE_PERCENT=40
ALERT_COST_DAILY_SPIKE_PERCENT=35
ALERT_COST_ABOVE_AVG_MULTIPLIER=1.5
ALERT_MIN_REQUESTS_FOR_COST_ALERT=150
ALERT_COST_DAILY_MAX_DOLLARS=10
ODDS_CB_FAILURE_THRESHOLD=5
ODDS_CB_COOLDOWN_SECONDS=180
# Must be >= the slowest tier cadence in seconds, with margin for cycle
# duration and the 30s due-tolerance. With tier 3 at 30 min (1800s), the
# worst-case gap between two successive syncs of a tier-3 sport is
# ~1800 + 90s cycle time + 30s tolerance = ~1920s. 2100 gives a safety
# cushion before matches get flagged stale and hidden from the UI.
SPORTSBOOK_MAX_SYNC_AGE_SECONDS=2100

# Per-endpoint rate limits (file-backed, APCu hot path)
# Format: RATE_LIMIT_<ENDPOINT>_MAX and RATE_LIMIT_<ENDPOINT>_WINDOW (seconds)
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_ADMIN_LOGIN_MAX=5
RATE_LIMIT_ADMIN_LOGIN_WINDOW=60
RATE_LIMIT_AGENT_LOGIN_MAX=5
RATE_LIMIT_AGENT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_PLACE_BET_MAX=20
RATE_LIMIT_PLACE_BET_WINDOW=60
RATE_LIMIT_DEPOSIT_REQUEST_MAX=5
RATE_LIMIT_DEPOSIT_REQUEST_WINDOW=60
RATE_LIMIT_WITHDRAWAL_REQUEST_MAX=5
RATE_LIMIT_WITHDRAWAL_REQUEST_WINDOW=60
RATE_LIMIT_SUPPORT_TICKET_MAX=5
RATE_LIMIT_SUPPORT_TICKET_WINDOW=300
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_PASSWORD_RESET_WINDOW=300

# Optional: protect /api/_php/metrics in production via X-Metrics-Key
METRICS_API_KEY=

# Phase 1 optimization toggle: SQL-level projection for /api/matches?payload=core
# Enabled from local A/B benchmark (lower avg and p95 than full-doc + PHP trim).
SPORTSBOOK_CORE_SQL_PROJECTION=true

# Phase 2 optimization: Write path & worker rate limiting
# Batch insert settings
WRITE_BUFFER_BATCH_SIZE=50

# Worker rate limits (prevent background jobs from starving API requests)
ODDS_SYNC_MAX_CALLS_PER_MINUTE=3
ODDS_SYNC_BATCH_SIZE=500
ODDS_SYNC_MAX_DURATION_SECONDS=30
SETTLEMENT_WORKER_MAX_CALLS_PER_MINUTE=5
SETTLEMENT_WORKER_BATCH_SIZE=100

# Cache TTL settings (seconds)
CACHE_TTL_MATCHES_BY_SPORT=30
CACHE_TTL_ODDS=5
CACHE_TTL_USER_BALANCE=10
CACHE_TTL_AGENT_COMMISSION=3600
CACHE_TTL_SETTLEMENT_STATE=5
CACHE_STALE_REVALIDATE_GRACE_SECONDS=300

# Phase 3C realtime websocket settings
WS_ENABLED=true
WS_HOST=0.0.0.0
WS_PORT=5001
# Set a strong secret in production; required for /api/realtime/publish
WS_PUBLISH_KEY=

# Phase 3D cost monitoring model (tune for your infra pricing)
COST_BASE_REQUEST_UNITS=1.0
COST_DB_QUERY_UNITS=0.5
COST_CACHE_MISS_UNITS=0.35
COST_CACHE_HIT_SAVINGS_UNITS=0.12
COST_DURATION_MS_PER_UNIT=250
COST_UNIT_DOLLARS=0.00025

# TheRundown.io — kept here too for parity with root .env. Env::load()
# reads root .env first; these are the fallback if only the backend
# directory is deployed.
RUNDOWN_API_KEY=6a44f3e82176acb0ab522c72d70abfc4145e6da7cb20ec9fc6cb3d7e9a2494c7
RUNDOWN_LIVE_ENABLED=false
# Worker-level live-odds provider toggles (read by odds-worker.php).
# Both off = no live odds dispatch. Currently OddsAPI-only.
LIVE_ODDS_ODDSAPI=true
LIVE_ODDS_RUNDOWN=false
RUNDOWN_LIVE_TICK_SECONDS=90
RUNDOWN_LIVE_FRESHNESS_SECONDS=300
RUNDOWN_LIVE_MAX_SPORTS_PER_TICK=20
RUNDOWN_LIVE_REQUEST_DELAY_MS=1100
# Cron-callable tick endpoints (kept here for fallback when Env::load
# can't find root /.env — production typically uses root, but the local
# backend dir is the standard fallback).
RUNDOWN_TICK_SECRET=b37705368c95440e6c94fdb972809e63eaa5b688e47d4e5125b2d75d41a777a9
LIVE_FRESHNESS_SECONDS_DEFAULT=90
LIVE_TICK_MIN_INTERVAL_SECONDS=30
PREMATCH_FRESHNESS_SECONDS_DEFAULT=300
PREMATCH_MAX_SPORTS_PER_TICK=8
# Live odds: enforce 60s minimum between user-triggered syncs (matches
# your 60-90s refresh policy; backend Rundown cron also ticks every 90s).
USER_LIVE_SYNC_MIN_INTERVAL_SECONDS=60
USER_PREMATCH_SYNC_MIN_INTERVAL_SECONDS=300

# Pre-match odds on-demand refresh rate limits.
# Policy: 1 refresh per user per 5 minutes; 3 per IP per 5 minutes (shared
# IPs / NAT). Dedup window is 290s so the in-flight cache never shadows the
# per-user 300s limit, avoiding a race where a deduplicated hit burns a slot.
ODDS_REFRESH_USER_LIMIT_MAX=1
ODDS_REFRESH_USER_LIMIT_WINDOW_SECONDS=300
ODDS_REFRESH_IP_LIMIT_MAX=3
ODDS_REFRESH_IP_LIMIT_WINDOW_SECONDS=300
ODDS_REFRESH_DEDUP_WINDOW_SECONDS=290
RUNDOWN_MAX_CALLS_PER_MINUTE=30
ODDSAPI_MAX_CALLS_PER_MINUTE=60