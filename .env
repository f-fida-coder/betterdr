APP_ENV=development
PORT=5000
CORS_ALLOW_ALL=true
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5000,http://127.0.0.1:5000,http://localhost:5050,http://127.0.0.1:5050,https://bettorplays247.com,https://www.bettorplays247.com
JWT_SECRET=d3ec06a495135eb2e6e56e5398447dda6aaf96cf795ab1192521a8cf22ff703a
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
# ─── TheRundown odds source (Ultra plan) ─────────────────────────────
# Paste your API key here. Without a key the integration is disabled —
# the site keeps running but the matches table stays empty until the
# key is added. Get it from your therundown.io account dashboard.
RUNDOWN_API_KEY=5c0a29962de0e2908bfd8e01818491f366081b5a4f1821891db27d3a2bbf59ab
RUNDOWN_BASE_URL=https://therundown.io/api/v2
# HTTP request timeout (seconds) for upstream calls.
RUNDOWN_TIMEOUT_SECONDS=10
# Sportsbooks to pull (comma-separated affiliate IDs). Empty = accept
# every affiliate Rundown returns (noisy; not recommended). Common IDs:
#   2 Bovada · 3 Pinnacle · 6 BetOnline · 11 LowVig · 12 Bodog
#   19 DraftKings · 22 BetMGM · 23 FanDuel · 24 theScore Bet
#   25 Kalshi · 26 Polymarket
RUNDOWN_AFFILIATE_IDS=19
# UTC offset minutes for the day-boundary on /sports/{id}/events/{date}.
# 300 = US Central, 240 = US Eastern, 360 = Mountain, 420 = Pacific.
# Makes "today" mean operator-local today, not midnight-UTC today.
RUNDOWN_DATE_OFFSET_MINUTES=300
# Days of pre-match coverage to keep loaded. 4 days catches every
# major tournament's quarter-final → final without dragging in
# month-out futures.
RUNDOWN_PREMATCH_DAYS_AHEAD=2
# Delta polling cadence (seconds). The live-tick cron polls
# /markets/delta this often. Cursors older than 30 minutes are
# rejected upstream; the worker auto-rebootstraps when that happens.
RUNDOWN_DELTA_POLL_SECONDS=5
# Hard upper bound on Rundown HTTP calls per minute (across all workers).
# Last-line guard against runaway loops. Ultra has very high data-point
# caps — 120/min is plenty. Set to 0 to disable.
RUNDOWN_MAX_CALLS_PER_MINUTE=120
# Worker tick cadences — match the Rundown efficient-polling guide:
#   docs.therundown.io/guides/efficient-polling
# Worker wakes every RUNDOWN_WORKER_TICK_SECONDS seconds. Each wake:
#   - polls /markets/delta every N market-delta ticks (price changes)
#   - polls /api/v2/delta  every N event-delta ticks  (score/status)
#   - does a full /events  every N full-refresh ticks (safety net)
RUNDOWN_WORKER_TICK_SECONDS=5
RUNDOWN_LIVE_MARKET_DELTA_EVERY_TICKS=6     # → live odds refresh every 30 s
RUNDOWN_LIVE_EVENT_DELTA_EVERY_TICKS=6      # → live scores refresh every 30 s
RUNDOWN_LIVE_FULL_REFRESH_EVERY_TICKS=120   # → full safety-net refresh every 10 min
RUNDOWN_PREMATCH_EVERY_N_TICKS=60           # → prematch rotation every 5 min
# Active polling window (hours ahead). Any sport with at least one live
# or scheduled game in this window gets the same 5-s market-delta poll
# as live sports. Lower = focus on near-term games; higher = upcoming
# odds for further-out games stay fresh too. 24 h is a reasonable default.
RUNDOWN_ACTIVE_WINDOW_HOURS=24
# ── Sport coverage ────────────────────────────────────────────────────
# true (default): sync EVERY sport Rundown carries — NCAAF, NFL, MLB,
#   NBA, NCAAB, NHL, UFC/MMA, WNBA, CFL, MLS, EPL, Ligue 1, Bundesliga,
#   La Liga, Serie A, UCL, UEFA Euro, FIFA, J-League, IPL, T20,
#   Politics, all playoffs/preseasons, UEFA EL, ATP, WTA (34 total).
# false: fall back to the union of ODDS_TIER1_SPORTS + ODDS_TIER2_SPORTS
#   + ODDS_ALLOWED_SPORTS (operator-curated subset).
RUNDOWN_SYNC_ALL_SPORTS=false
# Optional: comma-separated sport_ids to skip even when sync-all is on.
# Examples: 22 (Politics), 32 (NBA Summer League). Empty = no exclusions.
RUNDOWN_SYNC_EXCLUDE_SPORT_IDS=
# ── Realtime WebSocket (rundown-ws-daemon.php) ────────────────────────
# Persistent connection to wss://therundown.io/api/v2/ws/markets for
# sub-second odds updates. Started by scripts/rundown-ws-watchdog.sh
# (a 1-min cron line restarts it if it dies — same pattern as odds-worker).
# Set RUNDOWN_WS_ENABLED=false to keep WS off and rely on REST polling only.
RUNDOWN_WS_ENABLED=false
RUNDOWN_WS_URL=wss://therundown.io/api/v2/ws/markets
# Stream filters (comma-separated). Empty = receive every message for
# the books your key has access to. Specific sport_ids / market_ids
# trim the firehose. By default we subscribe to all core market IDs.
RUNDOWN_WS_SPORT_IDS=
RUNDOWN_WS_MARKET_IDS=
RUNDOWN_WS_AFFILIATE_IDS=
RUNDOWN_WS_EVENT_IDS=
# If no frame arrives within this many seconds (Rundown sends heartbeats
# every 15 s, so 60 s of silence = something's wrong), drop and reconnect.
RUNDOWN_WS_SILENCE_TIMEOUT_SECONDS=60
RUNDOWN_WS_RECONNECT_MIN_SECONDS=2
RUNDOWN_WS_RECONNECT_MAX_SECONDS=60
RUNDOWN_WS_READ_TIMEOUT_MS=1000
RUNDOWN_WS_LOG_EVERY_SECONDS=60
RUNDOWN_WS_MAX_RUNTIME_SECONDS=21600    # voluntary restart every 6 h
# Frontend display ordering for bookmakers in the odds UI. Independent
# of RUNDOWN_AFFILIATE_IDS — that controls which books we PULL; this
# controls the order we DISPLAY them in. Unknown keys are skipped.
ODDS_PREFERRED_BOOKMAKERS=draftkings,fanduel,betmgm,pinnacle
# Bulk /odds time window (hours ahead of now). Empty/0 = no filter.
# Trims long-tail futures (golf majors months out) from prematch payloads.
# 96 = 4 days; tournament finals stay visible, deep futures get filtered.
# Does NOT apply to live odds (which would filter out in-progress events) or
# per-event prop sync (already targets a single event by ID).
ODDS_TIME_WINDOW_HOURS=96
MANUAL_FETCH_MODE=false

# Live full-sweep cadence (seconds). Each tick pulls odds + scores for
# every sport with a live event. Default 10 s is comfortably ahead of
# the upstream odds source's cache.
LIVE_FULL_TICK_SECONDS=10
# Scores-only sub-tick (seconds). Runs in the gaps between full sweeps
# and polls the upstream scores endpoint ONLY (no odds). Keeps the score
# on the board fresh without burning odds quota. Pre-gated to sports
# with at least one match in the active window so quiet hours cost
# ~zero quota. Cannot exceed LIVE_FULL_TICK_SECONDS (worker clamps it).
LIVE_SCORES_TICK_SECONDS=20
# Phase 3 starvation sweep — safety net that catches matches whose
# `lastOddsSyncAt` has aged past the live freshness window despite
# the main tier scheduler. Cheap when system is healthy (zero rows →
# zero upstream calls); refreshes ONLY core h2h/spreads/totals odds
# (preserves extendedMarkets / scores / status).
#   * STARVED_SWEEP_TICK_SECONDS: how often the sweep runs (seconds).
#     0 disables the sweep entirely (not recommended).
#   * STARVED_SWEEP_AGE_THRESHOLD_SECONDS: a row is "starved" if its
#     lastOddsSyncAt is older than this. Match LIVE_FRESHNESS_SECONDS_DEFAULT.
#   * STARVED_SWEEP_COOLDOWN_SECONDS: per-sport cooldown after a
#     force-fetch — a stuck row can't trigger /odds every tick.
#   * STARVED_SWEEP_MAX_SPORTS_PER_TICK: blast-radius cap so a major
#     outage (50 sports stale) can't blow through quota in one sweep.
STARVED_SWEEP_TICK_SECONDS=30
STARVED_SWEEP_AGE_THRESHOLD_SECONDS=90
STARVED_SWEEP_COOLDOWN_SECONDS=60
STARVED_SWEEP_MAX_SPORTS_PER_TICK=5
# Worker main cycle = 90 s. Every wake fetches every tier so no sport
# is ever more than 90 s stale on the pre-match path. Live odds tick
# every 10 s independently (LIVE_FULL_TICK_SECONDS).
ODDS_CRON_MINUTES=1.5
# Auto-discover every active sport from /v4/sports?all=false instead of
# relying on the static ODDS_ALLOWED_SPORTS list. Lets seasons come and
# go without env edits (e.g. French Open auto-appears once Madrid ends).
# Outright-only keys (*_winner) and anything in ODDS_DISCOVERY_EXCLUDE
# are still filtered out at the resolveSportsList() gate.
ODDS_AUTO_DISCOVER_SPORTS=true
ODDS_DISCOVERY_EXCLUDE=politics_us_presidential_election_winner
# Tiered cadence: each sport belongs to exactly one tier. All three
# tiers now share the 90 s cadence — quota is not a constraint for this
# deployment, so we trade API calls for uniformly fresh odds across
# every league.
ODDS_TIER1_SPORTS=basketball_nba,cricket_ipl,soccer_epl,soccer_uefa_champs_league,soccer_spain_la_liga,baseball_mlb,icehockey_nhl,tennis_atp_madrid_open,tennis_atp_french_open,tennis_wta_french_open
ODDS_TIER1_CRON_MINUTES=1.5
ODDS_TIER2_SPORTS=soccer_italy_serie_a,soccer_germany_bundesliga,soccer_france_ligue_one,soccer_usa_mls,cricket_odi,cricket_psl,tennis_wta_madrid_open,basketball_euroleague,basketball_wnba,mma_mixed_martial_arts,boxing_boxing
ODDS_TIER2_CRON_MINUTES=1.5
ODDS_TIER3_CRON_MINUTES=1.5
# Tier 3 extended sync now ON since credits aren't a constraint — gives
# all sports player props / alt lines / team totals / period markets.
ODDS_TIER3_EXTENDED_SYNC=true
ODDS_EXTENDED_SYNC_ENABLED=true
# Worker throughput cap. Was 3/min — that capped a full sport-list
# cycle at >10 min and was the actual bottleneck behind "26 min late".
# 30/min lets a full ~30-sport refresh complete within one cron cycle.
ODDS_SYNC_MAX_CALLS_PER_MINUTE=30
ODDS_SYNC_MAX_DURATION_SECONDS=60
# Per-match stale threshold. Now > slowest tier (5 min = 300s) plus
# cycle time + safety. 600s = 10 min keeps the global gate aggressive
# (banner appears within 5 min of worker death) while letting individual
# matches breathe a bit. Per-match check has its own higher threshold
# in code (matchStaleAfterSeconds, defaults 1500s).
SPORTSBOOK_MAX_SYNC_AGE_SECONDS=600
# Per-match stale threshold (used only by per-match check, not global
# gate). Generous since auto-poll + push keep individual rows fresh.
SPORTSBOOK_MATCH_STALE_AGE_SECONDS=900
# 5 s shared cache cuts MySQL load when multiple users hit /api/matches
# in the same second. Worker writes every 90 s, so 5 s adds at most 5 s
# to the staleness ceiling — safe for live betting. Bet placement
# re-validates odds server-side regardless of cache age.
SPORTSBOOK_MATCHES_CACHE_TTL_SECONDS=5
SPORTSBOOK_MATCHES_SPORTS_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_REFRESH_COOLDOWN_SECONDS=0
# Health snapshot cache TTL — keeps the staleness gate evaluation fresh.
SPORTSBOOK_HEALTH_CACHE_TTL_SECONDS=5
# On-demand refresh endpoint (POST /api/odds/refresh/{sport_key}).
# All knobs for this feature live in THIS file — do not duplicate in
# php-backend/.env. The backend reads from the root first; backend-local
# values only apply if the key is absent here.
ODDS_REFRESH_IP_LIMIT_MAX=15
ODDS_REFRESH_IP_LIMIT_WINDOW_SECONDS=60
ODDS_REFRESH_USER_LIMIT_MAX=10
ODDS_REFRESH_USER_LIMIT_WINDOW_SECONDS=60
# In-flight dedup window: within this many seconds after a refresh, a second
# caller for the same sport reuses the first caller's result without hitting
# upstream. Matches the button cooldown the frontend enforces.
ODDS_REFRESH_DEDUP_WINDOW_SECONDS=20
# Sharp-protection threshold for bet placement. If a match's odds are
# older than this when a user submits, the backend force-fetches the
# sport upstream BEFORE comparing the user's accepted price to the
# official one. Lower = better protection but +1-3s latency on each
# bet placement when the match is stale; higher = less protection but
# faster placements when odds are recently synced.
BET_TIME_ODDS_FRESH_SECONDS=30

# ── Live-odds + scoreboard metadata ───────────────────────────────────
# Primary live + prematch odds source is TheRundown — see config block
# near the top of this file.
# ESPN scoreboard side-channel: enriches matches with team records (W-L)
# and broadcast network names. Free, unauthenticated. Tick interval is
# independent of the live-odds tick since records change on game-end
# pace, not minute-to-minute.
LIVE_ODDS_ESPN_META=true
ESPN_META_TICK_SECONDS=300
# Cron-callable tick secret (set anything for local testing — production
# uses a hex string from `openssl rand -hex 32`).
INTERNAL_TICK_SECRET=b37705368c95440e6c94fdb972809e63eaa5b688e47d4e5125b2d75d41a777a9
# Live freshness gate: drop a row from Live Now if its lastOddsSyncAt is
# older than this. Per-sport overrides via LIVE_FRESHNESS_SECONDS_<SPORT_KEY>.
LIVE_FRESHNESS_SECONDS_DEFAULT=90
LIVE_TICK_MIN_INTERVAL_SECONDS=30
PREMATCH_FRESHNESS_SECONDS_DEFAULT=300
PREMATCH_MAX_SPORTS_PER_TICK=4
USER_LIVE_SYNC_MIN_INTERVAL_SECONDS=15
USER_PREMATCH_SYNC_MIN_INTERVAL_SECONDS=30
# Upstream call cap lives in RUNDOWN_MAX_CALLS_PER_MINUTE (top of file).
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
ODDS_SCORES_DAYS_FROM=0
IP_BLOCKING_ENABLED=true
DUPLICATE_IP_BLOCK_ENABLED=false
IP_ALLOWLIST=::1,127.0.0.1
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=betterdr_local
MYSQL_USER=root
MYSQL_PASSWORD=1245!
MYSQL_TABLE_PREFIX=
