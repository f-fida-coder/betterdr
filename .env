# Stale threshold for the backend `isBettable` flag. 3 hours tolerates
# ~12 consecutive failed 15m sync cycles per sport — well past the tail
# of Odds API rate-limit flakiness. Frontend additionally shows stale
# matches with disabled bet buttons (never hides them on staleness),
# so the UI stays populated even at higher ages.
SPORTSBOOK_MAX_SYNC_AGE_SECONDS=10800
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
ODDS_SCORES_DAYS_FROM=0
IP_BLOCKING_ENABLED=true
