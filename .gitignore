# Dependencies
node_modules/
# OS files
.DS_Store

# Production deploy bundle backend copies (regenerated by scripts/package-prod.sh)
# The frontend dist/ assets are tracked, but the PHP/api copies inside dist/
# are produced at build time and contain secrets — never commit them.
dist/api/
dist/php-backend/
dist/env.runtime


# Env files — must NEVER be tracked (contain secrets). Applies in every dir.
# .env.example files stay tracked because they're templates.
.env
.env.*
!.env.example

bundle-stats.html



# Local odds-analysis spreadsheets — not part of the app (ad-hoc data files)
Book2.csv
odds_comparison.xlsx

# Versioned production release snapshots (tools/deploy/build-release.sh).
# Local build artifacts for rollback only — never source, never committed.
releases/

# Pre-deploy DB snapshots (php-backend/scripts/backup-store.php).
# Gzipped SQL dumps containing PII + money rows — NEVER commit.
backups/

# Server runtime files — live ONLY on the VPS working tree, never in git.
# env.runtime holds APP_ENV=production (deleting it silently drops CLI
# workers into dev mode — see project_cli_env_split); storage/ is runtime
# logs/cache. Ignored so a server-side `git status` stays clean and these
# can never be swept up by an accidental `git add -A` or `git clean`.
env.runtime
php-backend/storage/
