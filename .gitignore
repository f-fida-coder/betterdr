# Dependencies
node_modules/

# OS files
.DS_Store

# Production deploy bundle backend copies (regenerated by scripts/package-prod.sh)
# The frontend dist/ assets are tracked, but the PHP/api copies inside dist/
# are produced at build time and contain secrets — never commit them.
dist/api/
dist/php-backend/
dist/.env
dist/env.runtime
dist/php-backend/.env
dist/php-backend/env.runtime

# Root env files — must NEVER be tracked. Currently still tracked from
# earlier history; remove with `git rm --cached .env .env.production .env.copy`
# and rotate every secret. See php-backend/config/tier-c-secrets-rotation.md.
# .env.example stays tracked because it's the template.
.env
.env.production
.env.copy
