# ── App ─────────────────────────────────────────────────────────────────────
PORT=5000
APP_ENV=production                   # production | development
VITE_ENABLE_MATCH_STREAM=true

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=sports_betting
MYSQL_USER=root
MYSQL_PASSWORD=

# ── Redis (OPTIONAL — Tier B cache layer) ───────────────────────────────────
# Leave REDIS_HOST empty to disable Redis entirely. RedisCache becomes a
# silent no-op and every caller falls back to its existing data source —
# the site keeps working unchanged. Set REDIS_HOST to enable.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_PREFIX=betterdr:
# Conservative timeout — we'd rather miss the cache than block the request.
REDIS_TIMEOUT_MS=100

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be >= 32 chars. Server refuses to start in production if weak/missing.
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# ── CORS (REQUIRED in production) ───────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Empty = all cross-origin blocked.
CORS_ORIGIN=https://yourdomain.com

# ── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Live odds cadence ─────────────────────────────────────────────────────────
# Live full-sweep cadence (seconds). Each tick pulls odds + scores for
# every sport with a live event.
LIVE_FULL_TICK_SECONDS=10

# ── Sports API (TheRundown, Ultra plan) ──────────────────────────────────
# Paste your API key here — without it the integration is disabled and the
# matches table stays empty. Key comes from your therundown.io dashboard.
RUNDOWN_API_KEY=
RUNDOWN_BASE_URL=https://therundown.io/api/v2
RUNDOWN_TIMEOUT_SECONDS=10
# Sportsbooks to pull (comma-separated affiliate IDs). See
# https://docs.therundown.io/reference/affiliates — common values:
#   2 Bovada · 3 Pinnacle · 19 DraftKings · 22 BetMGM · 23 FanDuel
RUNDOWN_AFFILIATE_IDS=3,19,22,23,24
RUNDOWN_DATE_OFFSET_MINUTES=300
RUNDOWN_PREMATCH_DAYS_AHEAD=4
RUNDOWN_DELTA_POLL_SECONDS=5
RUNDOWN_MAX_CALLS_PER_MINUTE=120
ODDS_ALLOWED_SPORTS=basketball_nba,americanfootball_nfl,soccer_epl,baseball_mlb,icehockey_nhl
ODDS_CACHE_TTL_MINUTES=10
# ──────────────────────────────────────────────────────────────────────────
# ODDS REFRESH OPTIMIZATION (May 2026)
# Worker updates DB every 90 seconds (was 10 min) for near-real-time odds.
# Frontend polls every 15s for live views (was 30s).
# Combined: max odds staleness 15–90 seconds (was 10–30 minutes).
# ──────────────────────────────────────────────────────────────────────────
ODDS_CRON_MINUTES=1.5
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
SPORTS_API_MAX_CALLS_PER_DAY=500
MANUAL_FETCH_MODE=false
# DISABLED: live betting requires fresh data per request. Set TTL <= 0 to
# bypass SharedFileCache+APCu in MatchesController. Re-enable with proper
# invalidation when scaling to 1000+ DAU.
SPORTSBOOK_MATCHES_CACHE_TTL_SECONDS=0
SPORTSBOOK_MATCHES_SPORTS_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_REFRESH_COOLDOWN_SECONDS=0
SPORTSBOOK_HEALTH_CACHE_TTL_SECONDS=10

# ── Live odds + ESPN scoreboard meta ──────────────────────────────────────────
# Primary live + prematch odds source is TheRundown (see RUNDOWN_* block
# above). ESPN's free public scoreboard is a side-channel that adds team
# records (W-L) and broadcast network names. ESPN endpoint is
# unauthenticated; no key needed.
LIVE_ODDS_ESPN_META=true
# Records change at game-end pace, not minute-to-minute, so 5 min is plenty.
ESPN_META_TICK_SECONDS=300
# Cron-callable internal tick endpoints (Hostinger / shared hosting).
# Generate with `openssl rand -hex 32` and pass the same value as the
# X-Tick-Secret header in your cron line:
#   * * * * * curl -X POST -H "X-Tick-Secret: $SECRET" /api/internal/prematch-tick
INTERNAL_TICK_SECRET=REPLACE_WITH_HEX_SECRET
# Live freshness gate (default 90s). Per-sport overrides:
#   LIVE_FRESHNESS_SECONDS_CRICKET_IPL=120
#   LIVE_FRESHNESS_SECONDS_SOCCER_SPAIN_LA_LIGA=90
LIVE_FRESHNESS_SECONDS_DEFAULT=90
LIVE_TICK_MIN_INTERVAL_SECONDS=5
PREMATCH_FRESHNESS_SECONDS_DEFAULT=300
PREMATCH_MAX_SPORTS_PER_TICK=8
USER_LIVE_SYNC_MIN_INTERVAL_SECONDS=15
USER_PREMATCH_SYNC_MIN_INTERVAL_SECONDS=30
# Upstream call cap lives in RUNDOWN_MAX_CALLS_PER_MINUTE (top of Sports API section).
