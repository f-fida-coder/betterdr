# ── App ─────────────────────────────────────────────────────────────────────
PORT=5000
APP_ENV=production                   # production | development
VITE_ENABLE_MATCH_STREAM=true

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=sports_betting
MYSQL_USER=root
MYSQL_PASSWORD=
# Optional prefix prepended to every table name. Leave empty for none.
MYSQL_TABLE_PREFIX=

# ── Redis (OPTIONAL — Tier B cache layer) ───────────────────────────────────
# Leave REDIS_HOST empty to disable Redis entirely. RedisCache becomes a
# silent no-op and every caller falls back to its existing data source —
# the site keeps working unchanged. Set REDIS_HOST to enable.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_PREFIX=betterdr:
# Conservative timeout — we'd rather miss the cache than block the request.
REDIS_TIMEOUT_MS=100

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be >= 32 chars. Server refuses to start in production if weak/missing.
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# ── CORS (REQUIRED in production) ───────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Empty = all cross-origin blocked.
CORS_ORIGIN=https://yourdomain.com

# ── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Live odds cadence ─────────────────────────────────────────────────────────
# Live full-sweep cadence (seconds). Each tick pulls odds + scores for
# every sport with a live event.
LIVE_FULL_TICK_SECONDS=10

# ── Realtime push to the browser (WebSocket) ─────────────────────────────────
# Upstream: hold a persistent Rundown WebSocket → DB stays ~sub-second fresh.
RUNDOWN_WS_ENABLED=true
RUNDOWN_WS_URL=wss://therundown.io/api/v2/ws/markets
# Subscription filters (comma-separated). Empty = use the RUNDOWN_AFFILIATE_IDS /
# active sports defaults; set to scope the upstream stream to specific ids.
RUNDOWN_WS_AFFILIATE_IDS=
RUNDOWN_WS_SPORT_IDS=
RUNDOWN_WS_EVENT_IDS=
RUNDOWN_WS_MARKET_IDS=
# Connection lifecycle (seconds). Reconnect backoff floors/ceilings, the
# no-message silence timeout that forces a reconnect, and a hard max runtime
# after which the daemon exits cleanly so the watchdog respawns it (6h).
RUNDOWN_WS_RECONNECT_MIN_SECONDS=2
RUNDOWN_WS_RECONNECT_MAX_SECONDS=60
RUNDOWN_WS_SILENCE_TIMEOUT_SECONDS=60
RUNDOWN_WS_MAX_RUNTIME_SECONDS=21600
# Downstream: run ws-server.php so browsers get pushed odds events (proxied by
# nginx at /ws → 127.0.0.1:5001). With this off, clients fall back to the
# /api/sync/recent REST poll.
WS_ENABLED=true
WS_HOST=127.0.0.1
WS_PORT=5001
# Fast live score+inning sweep cadence (worker ticks; tick=5s, so 4 = 20s).
# Pulls current score/inning per live sport WITHOUT odds (no data-point cost)
# and patches score fields only — independent of the slow full refresh. Needed
# because the event-delta score poll is unusable at high event volume.
RUNDOWN_LIVE_SCORE_EVERY_TICKS=4
# Base odds-worker tick (seconds). All *_EVERY_TICKS cadences below are
# multiples of this tick.
RUNDOWN_WORKER_TICK_SECONDS=5
# Live cadences (in ticks): market delta = live odds (5s), event delta = live
# scores (15s), full refresh = safety-net resync (5min).
RUNDOWN_LIVE_MARKET_DELTA_EVERY_TICKS=1
RUNDOWN_LIVE_EVENT_DELTA_EVERY_TICKS=3
RUNDOWN_LIVE_FULL_REFRESH_EVERY_TICKS=60
# Prematch rotation cadence (ticks) and active-poll target window (hours).
RUNDOWN_PREMATCH_EVERY_N_TICKS=60
RUNDOWN_ACTIVE_WINDOW_HOURS=24
# Sync ALL discovered sports each pass; optionally exclude specific sport ids.
RUNDOWN_SYNC_ALL_SPORTS=true
RUNDOWN_SYNC_EXCLUDE_SPORT_IDS=

# ── Dedicated pre-match (upcoming) worker ─────────────────────────────────────
# Run prematch-worker.php (via prematch-worker-watchdog.sh cron) to refresh
# EVERY upcoming sport's odds in one pass on its own process, so it never
# blocks live scores/settlement. Set this true so odds-worker.php skips its own
# 8-at-a-time prematch rotation (avoids double-fetch).
PREMATCH_DEDICATED_WORKER=true
# How often the dedicated worker sweeps ALL sports (seconds).
PREMATCH_WORKER_INTERVAL_SECONDS=75

# Coalesce window (ms) for the `odds:sync` events the sync paths emit. The WS
# daemon applies ~1000 price ticks/min; this caps published events to at most
# one per sport per window so the event log + browser refetch stay light.
REALTIME_ODDS_EVENT_MIN_MS=1000

# ── Sports API (TheRundown, Ultra plan) ──────────────────────────────────
# Paste your API key here — without it the integration is disabled and the
# matches table stays empty. Key comes from your therundown.io dashboard.
RUNDOWN_API_KEY=
RUNDOWN_BASE_URL=https://therundown.io/api/v2
RUNDOWN_TIMEOUT_SECONDS=10
# Sportsbooks to pull (comma-separated affiliate IDs). See
# https://docs.therundown.io/reference/affiliates — common values:
#   2 Bovada · 3 Pinnacle · 19 DraftKings · 22 BetMGM · 23 FanDuel
RUNDOWN_AFFILIATE_IDS=3,19,22,23,24
RUNDOWN_DATE_OFFSET_MINUTES=300
RUNDOWN_PREMATCH_DAYS_AHEAD=4
RUNDOWN_DELTA_POLL_SECONDS=5
RUNDOWN_MAX_CALLS_PER_MINUTE=120
ODDS_ALLOWED_SPORTS=basketball_nba,americanfootball_nfl,soccer_epl,baseball_mlb,icehockey_nhl
ODDS_CACHE_TTL_MINUTES=10
# Auto-discover every sport the feed exposes (vs. ODDS_ALLOWED_SPORTS only),
# minus a comma-separated exclude list (e.g. perennial novelty markets).
ODDS_AUTO_DISCOVER_SPORTS=true
ODDS_DISCOVERY_EXCLUDE=politics_us_presidential_election_winner
# Score backfill window: how many days back to also pull final scores for
# settlement (0 = today only).
ODDS_SCORES_DAYS_FROM=0

# ── Supplemental odds source (The Odds API, 5M credits/mo plan) ──────────────
# SUPPLEMENTAL ONLY. TheRundown remains the sole, authoritative source for
# every sport/league/market it provides. The Odds API serves ONLY markets
# Rundown lacks; the hard allowlist lives in CODE (src/OddsApiAllowlist.php)
# — keys outside it cannot be fetched, and startup refuses if the allowlist
# ever collides with a Rundown-covered league. Key from the-odds-api.com
# dashboard; blank = supplemental feed disabled, Rundown unaffected.
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_TIMEOUT_SECONDS=10
# Cross-process cap on upstream calls/min (0 = off) — runaway-loop guard,
# separate throttle state from RUNDOWN_MAX_CALLS_PER_MINUTE.
ODDS_API_MAX_CALLS_PER_MINUTE=60
# Credit budget guard (x-requests-remaining header, persisted per response).
# Below SLOWDOWN every polling interval doubles; below CRITICAL the worker
# polls outrights only and raises an admin-visible alert.
ODDS_API_BUDGET_SLOWDOWN_REMAINING=500000
ODDS_API_BUDGET_CRITICAL_REMAINING=100000
# Tiered polling cadence (minutes) — read by the oddsapi worker (Chunk 3).
ODDS_API_POLL_OUTRIGHTS_MINUTES=10
ODDS_API_POLL_SOCCER_MINUTES=10
# Tighten soccer polling this close to kickoff (0 = no tightening).
ODDS_API_POLL_SOCCER_NEAR_KICKOFF_MINUTES=5
ODDS_API_NEAR_KICKOFF_WINDOW_HOURS=2
# Low-volume tier: boxing + NRL (fights/rugby categories, 2026-07-05).
# Zero-event passes are NORMAL — boxing goes weeks between cards and the
# NRL board empties between rounds. Same near-kickoff tightening applies.
ODDS_API_POLL_LOWVOLUME_MINUTES=10
# Card markets: per-event endpoint costs credits per event — only poll events
# inside the kickoff window. Sync gate default OFF; the free /events call +
# fail-closed Rundown matcher run BEFORE any paid per-event fetch. Player
# betting on cards is gated SEPARATELY (SPORTSBOOK_CARDS_BETTING_ENABLED,
# Cards-2/3) and stays off until the manual-grading admin UI is live.
ODDS_API_CARDS_SYNC_ENABLED=false
ODDS_API_POLL_CARDS_MINUTES=10
ODDS_API_CARDS_WINDOW_HOURS=48
# Player-facing cards gate: flips DISPLAY and PLACEMENT together (one shared
# serve-time gate). MANDATORY: stays false until the Cards-3 manual-grading
# admin UI is deployed — card bets can only be graded by an operator.
SPORTSBOOK_CARDS_BETTING_ENABLED=false
# Cards/corners go dark on both surfaces when the last card sync is older than
# this (default 1200s = two missed 10-min polls). Also dark the moment kickoff
# passes — cards/corners are prematch-only.
ODDS_API_CARDS_STALE_SECONDS=1200
# Manual/write-in bets ("phone bets"): an ADMIN books a custom free-text bet
# on a player's account (no matchId, no feed market) and grades it manually
# from the Manual Bets admin inbox. Placement gate only — grading stays
# available while false so in-flight bets can always be resolved.
MANUAL_BETS_ENABLED=false
# Per-bet stake ceiling for manual bets (dollars). The player's own maxBet
# still applies on top when it is lower; hard floor is $1.
MANUAL_BET_MAX_STAKE=500
# Master switch for the supplemental sync worker. false = the worker idles
# (zero upstream calls); the client itself stays inert without a key.
# Restart the worker (via its watchdog) after changing — env is cached at startup.
ODDS_API_SYNC_ENABLED=false
# Worker loop: scheduler tick + voluntary restart horizon (watchdog restarts it).
ODDS_API_WORKER_TICK_SECONDS=30
ODDS_API_WORKER_MAX_RUNTIME_SECONDS=21600
# Outrights tier gate — syncs futures boards (Super Bowl winner, golf majors,
# …) into the outrights table hourly. SYNC only: player-facing futures betting
# stays separately gated by SPORTSBOOK_OUTRIGHTS_BETTING_ENABLED (keep THAT
# off until the admin winner UI lands — futures grade manually).
ODDS_API_OUTRIGHTS_SYNC_ENABLED=false
# Soft "delayed/stale" badge window for theoddsapi rows ONLY (they poll every
# ~10 min vs Rundown's ~75s). HARD-CAPPED at 900s in code — config cannot
# stretch it further. Rundown rows keep PREMATCH_FRESHNESS_SECONDS_DEFAULT.
ODDS_API_PREMATCH_FRESHNESS_SECONDS=720
# ──────────────────────────────────────────────────────────────────────────
# ODDS REFRESH OPTIMIZATION (May 2026)
# Worker updates DB every 90 seconds (was 10 min) for near-real-time odds.
# Frontend polls every 15s for live views (was 30s).
# Combined: max odds staleness 15–90 seconds (was 10–30 minutes).
# ──────────────────────────────────────────────────────────────────────────
ODDS_CRON_MINUTES=1.5
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
SPORTS_API_MAX_CALLS_PER_DAY=500
MANUAL_FETCH_MODE=false
# DISABLED: live betting requires fresh data per request. Set TTL <= 0 to
# bypass SharedFileCache+APCu in MatchesController. Re-enable with proper
# invalidation when scaling to 1000+ DAU.
SPORTSBOOK_MATCHES_CACHE_TTL_SECONDS=0
SPORTSBOOK_MATCHES_SPORTS_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_REFRESH_COOLDOWN_SECONDS=0
SPORTSBOOK_HEALTH_CACHE_TTL_SECONDS=10
# Player-prop pending bets show only the player's own team crest (resolved at
# placement from the player's Rundown team_id) instead of both matchup crests.
# Kill-switch: set false to skip the per-placement /players lookup (UI then
# falls back to both crests). Best-effort — never blocks bet placement.
SPORTSBOOK_PROP_TEAM_LOGO_ENABLED=true
# Prop Builder team filter: tag each player prop with its team (from the two
# team rosters, cached) so users can filter players by team. Kill-switch: set
# false to skip the roster lookups (the team toggle then hides; player-name
# filter still works). Best-effort, display-only — never affects pricing/grading.
SPORTSBOOK_PROP_TEAM_FILTER_ENABLED=true

# ── Sportsbook pricing & line selection ──────────────────────────────────────
# Fallback flat juice (American) used when a market has no usable two-sided
# price to de-vig.
SPORTSBOOK_FLAT_JUICE_AMERICAN=-110
# Book preference order when consolidating a price. The generic list is the
# default; the per-market overrides take precedence for that market type.
SPORTSBOOK_PREFERRED_BOOKS=betmgm,draftkings,fanduel,pinnacle
SPORTSBOOK_PREFERRED_BOOKS_H2H=betmgm,draftkings,fanduel,pinnacle,sportsbetting,betonline
SPORTSBOOK_PREFERRED_BOOKS_SPREADS=sportsbetting,betonline,betmgm,draftkings,fanduel,pinnacle
SPORTSBOOK_PREFERRED_BOOKS_TOTALS=betmgm,draftkings,fanduel,pinnacle,sportsbetting,betonline
# Public board refresh: let an unauthenticated board view trigger a feed refresh
# (false = only the worker refreshes), with a lock so concurrent views coalesce.
SPORTSBOOK_PUBLIC_AUTO_REFRESH=false
SPORTSBOOK_PUBLIC_REFRESH_LOCK_SECONDS=30
# Alt-line ladder depth surfaced per side/direction. Empty = use platformsettings
# (alternateLinesPerSide), else default 1. Negative = UNLIMITED. Single source
# of truth for BOTH the display filter and the placement guard (AltLineCap).
SPORTSBOOK_ALT_LINES_PER_SIDE=
# Player-prop settlement gate. Money-critical: 'false' leaves prop bets PENDING
# (manual grade) rather than auto-grading. Enable only once prop grading is
# verified against the feed.
SPORTSBOOK_PROP_SETTLEMENT_ENABLED=false

# ── Feature gates (money-affecting — change deliberately) ─────────────────────
# Buy Points: comma-separated sport keys where bought points are offered.
# EMPTY = globally LOCKED (backend emits no alternateLines and rejects
# bought-point placement). e.g. baseball_mlb,basketball_nba
BUY_POINTS_ENABLED_SPORTS=
# Open parlay (add legs to a live parlay). '0' disables; anything else enables.
OPEN_PARLAY_ENABLED=1
OPEN_PARLAY_MAX_OPEN_PER_USER=3

# ── Security / abuse controls ────────────────────────────────────────────────
# IP blocking enforcement and the always-allowed list (never blocked).
IP_BLOCKING_ENABLED=true
IP_ALLOWLIST=::1,127.0.0.1
# Reject placements from an IP already tied to another open bet on the same
# selection (collusion guard). false = off.
DUPLICATE_IP_BLOCK_ENABLED=false

# ── Live odds + ESPN scoreboard meta ──────────────────────────────────────────
# Primary live + prematch odds source is TheRundown (see RUNDOWN_* block
# above). ESPN's free public scoreboard is a side-channel that adds team
# records (W-L) and broadcast network names. ESPN endpoint is
# unauthenticated; no key needed.
LIVE_ODDS_ESPN_META=true
# Records change at game-end pace, not minute-to-minute, so 5 min is plenty.
ESPN_META_TICK_SECONDS=300
# Cron-callable internal tick endpoints (Hostinger / shared hosting).
# Generate with `openssl rand -hex 32` and pass the same value as the
# X-Tick-Secret header in your cron line:
#   * * * * * curl -X POST -H "X-Tick-Secret: $SECRET" /api/internal/prematch-tick
INTERNAL_TICK_SECRET=REPLACE_WITH_HEX_SECRET
# Live freshness gate (default 90s). Per-sport overrides:
#   LIVE_FRESHNESS_SECONDS_CRICKET_IPL=120
#   LIVE_FRESHNESS_SECONDS_SOCCER_SPAIN_LA_LIGA=90
LIVE_FRESHNESS_SECONDS_DEFAULT=90
LIVE_TICK_MIN_INTERVAL_SECONDS=5
PREMATCH_FRESHNESS_SECONDS_DEFAULT=300
PREMATCH_MAX_SPORTS_PER_TICK=8
USER_LIVE_SYNC_MIN_INTERVAL_SECONDS=15
USER_PREMATCH_SYNC_MIN_INTERVAL_SECONDS=30
# Upstream call cap lives in RUNDOWN_MAX_CALLS_PER_MINUTE (top of Sports API section).
