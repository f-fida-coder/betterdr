# ── App ─────────────────────────────────────────────────────────────────────
PORT=5000
APP_ENV=production                   # production | development
VITE_ENABLE_MATCH_STREAM=true

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=sports_betting
MYSQL_USER=root
MYSQL_PASSWORD=

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be >= 32 chars. Server refuses to start in production if weak/missing.
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# ── CORS (REQUIRED in production) ───────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Empty = all cross-origin blocked.
CORS_ORIGIN=https://yourdomain.com

# ── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Sports API (The Odds API) ─────────────────────────────────────────────────
# Get key at: https://the-odds-api.com/
# REQUIRED if SPORTS_API_ENABLED=true — server will warn/error without it.
ODDS_API_KEY=REPLACE_ME
ODDS_API_REGIONS=us
ODDS_API_MARKETS=h2h,spreads,totals
ODDS_API_ODDS_FORMAT=american
ODDS_API_BOOKMAKERS=
ODDS_ALLOWED_SPORTS=basketball_nba,americanfootball_nfl,soccer_epl,baseball_mlb,icehockey_nhl
ODDS_CACHE_TTL_MINUTES=10
ODDS_CRON_MINUTES=10
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
SPORTS_API_MAX_CALLS_PER_DAY=500
MANUAL_FETCH_MODE=false
SPORTSBOOK_MATCHES_CACHE_TTL_SECONDS=30
SPORTSBOOK_MATCHES_SPORTS_CACHE_TTL_SECONDS=60
SPORTSBOOK_HEALTH_CACHE_TTL_SECONDS=10

# ── TheRundown.io (live odds overlay) ─────────────────────────────────────────
# Live Now is Rundown-only — pre-match comes from The Odds API, in-progress
# odds come from TheRundown via the odds-worker live tick. Get a key at:
# https://therundown.io/. Leave RUNDOWN_LIVE_ENABLED=false to disable entirely.
RUNDOWN_API_KEY=REPLACE_ME
RUNDOWN_LIVE_ENABLED=false
RUNDOWN_LIVE_TICK_SECONDS=90
RUNDOWN_LIVE_FRESHNESS_SECONDS=300
RUNDOWN_LIVE_MAX_SPORTS_PER_TICK=20
RUNDOWN_LIVE_REQUEST_DELAY_MS=1100
