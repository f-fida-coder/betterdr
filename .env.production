APP_ENV=production
PORT=5000
# Localhost origins removed — not safe in production. Add them back only for local testing.
CORS_ORIGIN=https://bettorplays247.com,https://www.bettorplays247.com
# REQUIRED: replace with a strong secret (openssl rand -hex 32)
JWT_SECRET=d3ec06a495135eb2e6e56e5398447dda6aaf96cf795ab1192521a8cf22ff703a
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
# ─── TheRundown odds source (Ultra plan) ─────────────────────────────
# Paste your API key here. Without a key the integration is disabled.
RUNDOWN_API_KEY=5c0a29962de0e2908bfd8e01818491f366081b5a4f1821891db27d3a2bbf59ab
RUNDOWN_BASE_URL=https://therundown.io/api/v2
RUNDOWN_TIMEOUT_SECONDS=10
# Sportsbooks to pull (comma-separated affiliate IDs):
#   2 Bovada · 3 Pinnacle · 6 BetOnline · 11 LowVig · 12 Bodog
#   19 DraftKings · 22 BetMGM · 23 FanDuel · 24 theScore Bet
#   25 Kalshi · 26 Polymarket
RUNDOWN_AFFILIATE_IDS=3,19,22,23,24
# UTC offset minutes for /sports/{id}/events/{date} day boundary.
RUNDOWN_DATE_OFFSET_MINUTES=300
RUNDOWN_PREMATCH_DAYS_AHEAD=4
RUNDOWN_DELTA_POLL_SECONDS=5
# Hard upper bound on Rundown HTTP calls per minute (guard rail).
RUNDOWN_MAX_CALLS_PER_MINUTE=120
# Worker tick cadences — see Rundown efficient-polling guide.
RUNDOWN_WORKER_TICK_SECONDS=5
RUNDOWN_LIVE_MARKET_DELTA_EVERY_TICKS=1     # 5 s live odds
RUNDOWN_LIVE_EVENT_DELTA_EVERY_TICKS=3      # 15 s live scores
RUNDOWN_LIVE_FULL_REFRESH_EVERY_TICKS=60    # 5 min safety net
RUNDOWN_PREMATCH_EVERY_N_TICKS=60           # 5 min prematch rotation (was 90 s; tuned for credit save + 5 min user-perceived cache)
RUNDOWN_ACTIVE_WINDOW_HOURS=24              # active-poll target window
# Sport coverage — true syncs every Rundown sport (34 total).
RUNDOWN_SYNC_ALL_SPORTS=true
RUNDOWN_SYNC_EXCLUDE_SPORT_IDS=
# Realtime WebSocket. Set false to keep REST-polling-only.
RUNDOWN_WS_ENABLED=true
RUNDOWN_WS_URL=wss://therundown.io/api/v2/ws/markets
RUNDOWN_WS_SPORT_IDS=
RUNDOWN_WS_MARKET_IDS=
RUNDOWN_WS_AFFILIATE_IDS=
RUNDOWN_WS_EVENT_IDS=
RUNDOWN_WS_SILENCE_TIMEOUT_SECONDS=60
RUNDOWN_WS_RECONNECT_MIN_SECONDS=2
RUNDOWN_WS_RECONNECT_MAX_SECONDS=60
RUNDOWN_WS_MAX_RUNTIME_SECONDS=21600
# Frontend display ordering for bookmakers.
ODDS_PREFERRED_BOOKMAKERS=draftkings,fanduel,betmgm,pinnacle
MANUAL_FETCH_MODE=false

# Live full-sweep cadence (seconds). Each tick pulls /odds + /scores for
# every sport with a live event.
LIVE_FULL_TICK_SECONDS=10
ODDS_CRON_MINUTES=2
SPORTS_API_ENABLED=true
ODDS_SCORES_ENABLED=true
ODDS_SCORES_DAYS_FROM=0
# Auto-discover every currently-active sport from /v4/sports (cached 1h).
# No hardcoded list needed; new seasons auto-appear in the sidebar.
ODDS_AUTO_DISCOVER_SPORTS=true
ODDS_DISCOVERY_EXCLUDE=politics_us_presidential_election_winner
IP_BLOCKING_ENABLED=true
DUPLICATE_IP_BLOCK_ENABLED=false
IP_ALLOWLIST=::1,127.0.0.1
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=u487877829_better_dr
MYSQL_USER=u487877829_bettordr
MYSQL_PASSWORD=Bettor.ok12
MYSQL_TABLE_PREFIX=

# Phase 13 performance controls
# Keep public reads fast under load: refreshes should run via cron/manual, not request path.
SPORTSBOOK_PUBLIC_AUTO_REFRESH=false
# Tiny shared cache to absorb traffic spikes without letting odds drift.
# TTL <= 0 bypasses SharedFileCache + APCu and always recomputes from DB.
# Tier B bump: 5s -> 15s. The odds-worker live tick is 90s, so 15s of
# drift is well within freshness tolerance and triples cache hit rate
# during traffic spikes.
# ROLLBACK: set back to 5 if you observe stale-odds bet rejections climb.
SPORTSBOOK_MATCHES_CACHE_TTL_SECONDS=15
# Tier B bump: 30s -> 60s. Sports list (leagues/sports menu) changes only
# when the odds-worker discovers a new sport — far slower than 60s.
# ROLLBACK: set back to 30 if menus appear stale after league rollovers.
SPORTSBOOK_MATCHES_SPORTS_CACHE_TTL_SECONDS=60
SPORTSBOOK_PUBLIC_CACHE_TTL_SECONDS=0
SPORTSBOOK_PUBLIC_REFRESH_COOLDOWN_SECONDS=0
SPORTSBOOK_PUBLIC_REFRESH_LOCK_SECONDS=30

# Live-odds + scoreboard metadata.
# Primary live + prematch odds source is TheRundown — see the
# RUNDOWN_* block near the top of this file. ESPN's free public
# scoreboard is a side-channel that adds team records (W-L) and
# broadcast network names.
# ESPN scoreboard tick. Records change at game-end pace, not minute-by-
# minute, so a 5 min interval is plenty.
LIVE_ODDS_ESPN_META=true
ESPN_META_TICK_SECONDS=300
# Shared secret for the cron-callable /api/internal/* tick endpoints.
# Required because Hostinger shared hosting can't run the long-lived
# odds-worker daemon — point a 1-min cron at the prematch tick URL with
# this header. Generate with: openssl rand -hex 32
INTERNAL_TICK_SECRET=b37705368c95440e6c94fdb972809e63eaa5b688e47d4e5125b2d75d41a777a9
# Live freshness gate — how old can a 'live' row's lastOddsSyncAt be
# before the LIVE NOW / effectively-live filters drop it from the
# match list. Aligned with ODDS_STALE_HARD_SECONDS=180 so the
# visibility window matches the bet-safety window: anything younger
# than this is still bettable, anything older is suspended anyway
# via applyBettingAvailability. The previous 90s value matched only
# the "delayed" badge threshold (ODDS_STALE_SOFT_SECONDS) — it left a
# 90-180s blind spot where rows were bettable but invisible, which is
# why LIVE NOW sometimes rendered empty while the default view still
# showed live matches. Per-sport overrides via
# LIVE_FRESHNESS_SECONDS_<UPPER_SPORT_KEY>, e.g.
#   LIVE_FRESHNESS_SECONDS_CRICKET_IPL=240
LIVE_FRESHNESS_SECONDS_DEFAULT=180
# Cron rate guard — skip a tick request that arrives within this many
# seconds of the last successful tick of the same type.
LIVE_TICK_MIN_INTERVAL_SECONDS=30
# Pre-match listing freshness — how old can a row's lastOddsSyncAt be
# before computeMatches() / computeAvailableSports() drop it from the
# sidebar and match list. Must be LONGER than the worker's full
# rotation cycle, otherwise some sports always sit just outside the
# window and disappear from the sidebar (the bug fixed in 03a3dd62).
# Full cycle today: 24 sports / 8 per batch × 5 min/batch = 15 min.
# 1200s = 20 min gives a comfortable buffer. Bet safety is unaffected
# — ODDS_STALE_HARD_SECONDS=180 and matchStaleAfterSeconds=25min
# independently suspend betting on any individual stale match.
PREMATCH_FRESHNESS_SECONDS_DEFAULT=1200
# Pre-match cron rotation cap. With 8 sports/tick at */5 min and ~24
# configured sports, every sport refreshes within ~3 ticks (15 min).
PREMATCH_MAX_SPORTS_PER_TICK=8
# Per-IP rate guard for user-triggered Refresh-button calls. Lower than
# the cron's 30s so a real user click feels instant.
USER_LIVE_SYNC_MIN_INTERVAL_SECONDS=15
# Per-IP per-sport rate guard for sport-tab on-demand sync.
USER_PREMATCH_SYNC_MIN_INTERVAL_SECONDS=30
# Upstream call cap lives in RUNDOWN_MAX_CALLS_PER_MINUTE (top of file).
