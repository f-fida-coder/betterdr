# Frontend environment variables for betterdr sportsbook
# Copy this to .env.production and set values for production

# Backend API URL
VITE_API_URL=https://yourdomain.com/api/index.php?path=

# ───────────────────────────────────────────────────────────────────────────
# ODDS REFRESH OPTIMIZATION (May 2026)
# ───────────────────────────────────────────────────────────────────────────

# Auto-poll intervals (milliseconds)
# Live view: 15s (was 30s) — closest real-time with reasonable bandwidth
VITE_MATCHES_POLL_LIVE_MS=15000

# Other views (Upcoming, Teaser, Parlay): 60s
VITE_MATCHES_POLL_OTHER_MS=60000

# Hidden tab: 120s (2 min) — keeps odds fresh when browser tab is in background
# On visibility change, switches back to appropriate interval above
VITE_MATCHES_POLL_HIDDEN_MS=120000

# ───────────────────────────────────────────────────────────────────────────
# Feature flags
# ───────────────────────────────────────────────────────────────────────────

VITE_ENABLE_MATCH_STREAM=true
VITE_ENABLE_LIVE_ODDS=true
