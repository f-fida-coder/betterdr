RewriteEngine On

# Keep users on one canonical origin so localStorage auth/session state is consistent.
RewriteCond %{HTTP_HOST} ^www\.bettorplays247\.com$ [NC]
RewriteRule ^ https://bettorplays247.com%{REQUEST_URI} [R=301,L,NE]

# Never rewrite API requests to index.html.
RewriteCond %{REQUEST_URI} ^/api(/|$) [NC]
RewriteRule ^ - [L]

# Phase 10: pre-compressed asset content negotiation.
# Vite emits sibling .br and .gz files alongside JS/CSS at build time
# (level 11 Brotli, level 9 gzip — slower at build, smaller wire bytes than
# any per-request compressor). When the client advertises a matching
# Accept-Encoding, rewrite to the static pre-compressed file. Apache then
# serves it with the same Content-Type but adds the Content-Encoding header
# below. Falls back to the uncompressed origin if the client doesn't accept
# (very rare today).
<IfModule mod_rewrite.c>
    # Brotli (preferred; saves another ~10-15% over gzip for text)
    RewriteCond %{HTTP:Accept-Encoding} br
    RewriteCond %{REQUEST_FILENAME}.br -s
    RewriteRule ^(.+\.(?:js|mjs|css|html|json|svg|wasm))$ $1.br [QSA,L]
    # Gzip fallback for older clients
    RewriteCond %{HTTP:Accept-Encoding} gzip
    RewriteCond %{REQUEST_FILENAME}.gz -s
    RewriteRule ^(.+\.(?:js|mjs|css|html|json|svg|wasm))$ $1.gz [QSA,L]
</IfModule>
<IfModule mod_headers.c>
    # Tag rewritten files with the right Content-Encoding so the browser decompresses.
    <FilesMatch "\.br$">
        Header set Content-Encoding br
        Header append Vary Accept-Encoding
    </FilesMatch>
    <FilesMatch "\.gz$">
        Header set Content-Encoding gzip
        Header append Vary Accept-Encoding
    </FilesMatch>
</IfModule>
# Force the original Content-Type on the rewritten files (Apache otherwise
# guesses application/octet-stream from the .br/.gz suffix).
<IfModule mod_mime.c>
    AddType application/javascript .js.br .mjs.br .js.gz .mjs.gz
    AddType text/css .css.br .css.gz
    AddType text/html .html.br .html.gz
    AddType application/json .json.br .json.gz
    AddType image/svg+xml .svg.br .svg.gz
    AddType application/wasm .wasm.br .wasm.gz
</IfModule>

# Serve static files directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Browser revalidates the SPA shell; CDN may cache briefly because assets are content-hashed.
<IfModule mod_headers.c>
<Files "index.html">
Header always set Cache-Control "public, max-age=0, must-revalidate, s-maxage=60, stale-while-revalidate=300"
Header always unset Pragma
Header always unset Expires
</Files>
SetEnvIfNoCase Request_URI "^/games/(baccarat|blackjack)/.*\.(html|js)$" IS_LOCAL_GAME_RUNTIME=1
Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0" env=IS_LOCAL_GAME_RUNTIME
Header always set Pragma "no-cache" env=IS_LOCAL_GAME_RUNTIME
Header always set Expires "0" env=IS_LOCAL_GAME_RUNTIME
# Hashed assets (JS/CSS in /assets/) are immutable — cache aggressively.
<FilesMatch "\.(js|css)$">
Header always set Cache-Control "public, max-age=31536000, immutable" "expr=%{REQUEST_URI} =~ m#^/assets/#"
</FilesMatch>
# Self-hosted icon/font CSS under /fonts/ — pin filenames will be updated by
# rebuilding the subset (Phase 6 subset-fontawesome.mjs). Cache 30 days.
<FilesMatch "\.css$">
Header always set Cache-Control "public, max-age=2592000" "expr=%{REQUEST_URI} =~ m#^/fonts/#"
</FilesMatch>
# Static images & icons — content changes rarely, safe to cache 30 days.
<FilesMatch "\.(png|jpe?g|gif|webp|svg|ico)$">
Header always set Cache-Control "public, max-age=2592000"
</FilesMatch>
# Fonts — effectively never change, cache 1 year.
<FilesMatch "\.(woff2?|ttf|otf|eot)$">
Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
# PWA manifest — refresh daily so install metadata stays current.
<Files "manifest.json">
Header always set Cache-Control "public, max-age=86400"
</Files>
# Make caches/CDNs aware that responses vary by Accept-Encoding.
Header append Vary "Accept-Encoding"
</IfModule>

# Defense-in-depth: deny any request for sourcemap files. Vite is
# configured (frontend/vite.config.js) to not emit maps, but if a stray
# .map ever ships, this rule prevents it from being served.
<FilesMatch "\.map$">
    Require all denied
</FilesMatch>

# SPA fallback for frontend routes only.
RewriteRule ^ index.html [L]
